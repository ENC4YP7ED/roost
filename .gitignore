# Secrets & runtime state — the SQLite file holds password hashes, wings
# daemon tokens and live sessions.
*.db
*.db-shm
*.db-wal
certs/

# Build output
backend/roost
dist-bin/
frontend/dist/
dbviewer-frontend/dist/
coverage.out

# Embedded assets are generated by `make`; placeholders keep go:embed happy.
backend/web/dist/*
!backend/web/dist/.gitkeep
backend/web/dbviewer/*
!backend/web/dbviewer/.gitkeep

# Dependencies
node_modules/

# Test artefacts
e2e/test-results/
e2e/playwright-report/
